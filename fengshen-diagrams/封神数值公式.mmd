%% title: 封神数值公式
flowchart LR
    START([⚔️ 攻击发起 / 技能触发]):::start

    %% =================================================
    %% Region 1
    %% =================================================
    subgraph R1["🔥 Region 1 · 原始伤害区"]
        direction LR
    
        M1["乘区1 · 攻击力<br/>输出 ＝ a.基础攻击 × ❪1 ＋ a.基础攻击加成❫ ＋ a.附加攻击"]:::formula
        A_M1_1[/"a.基础攻击 ATK_BASE<br/>整数 / 不可负"/]:::attr
        A_M1_2[/"a.基础攻击加成 ATK_BASE_PER<br/>万分比 / 可为负"/]:::attr
        A_M1_3[/"a.附加攻击 ATK_ADD<br/>整数 / 可为负"/]:::attr
        A_M1_1 -.-> M1
        A_M1_2 -.-> M1
        A_M1_3 -.-> M1
    
        M2_DEF["先计算 ¤计算防御值<br/>¤计算防御值 ＝ MAX❮ ❪b.防御 − a.无视防御❫ × ❪1 ＋ b.防御提升万分比 − b.防御降低万分比❫ − a.破防值 , 0 ❯"]:::interim
        M2["乘区2 · 防御率<br/>输出 ＝ MAX❮ 乘区1输出 × ❪1 − F防御率❪¤计算防御值❫ ＋ a.破防率❫ ＋ a.通用伤害附加值 − b.通用伤害减免值 ＋ a.条件伤害附加值 − b.条件伤害减免值 , 乘区1输出 × 0.05 保底5％ ❯"]:::formula
        A_M2_1[/"b.防御 DEF"/]:::attr
        A_M2_2[/"a.无视防御 ANTI_DEF"/]:::attr
        A_M2_3[/"b.防御提升万分比 DEF_PER"/]:::attr
        A_M2_4[/"a.防御降低万分比 ANTI_DEF_PER"/]:::attr
        A_M2_5[/"a.破防值 DEF_RED<br/>乘后扣 / 保值"/]:::attr
        A_M2_6[/"a.破防率 DEF_RED_PER"/]:::attr
        A_M2_7[/"a.通用伤害附加值 CMN_DMG_ADD"/]:::attr
        A_M2_8[/"b.通用伤害减免值 CMN_HURT_RED"/]:::attr
        A_M2_9[/"a.条件伤害附加值 COND_DMG_ADD"/]:::attr
        A_M2_10[/"b.条件伤害减免值 COND_HURT_RED"/]:::attr
        A_M2_1 -.-> M2_DEF
        A_M2_2 -.-> M2_DEF
        A_M2_3 -.-> M2_DEF
        A_M2_4 -.-> M2_DEF
        A_M2_5 -.-> M2_DEF
        M2_DEF --> M2
        A_M2_6 -.-> M2
        A_M2_7 -.-> M2
        A_M2_8 -.-> M2
        A_M2_9 -.-> M2
        A_M2_10 -.-> M2
    
        M3["乘区3 · 技能系数<br/>输出 ＝ 乘区2输出 × 技能系数 ＋ 技能固定值"]:::formula
        A_M3_1[/"技能系数 / 来自技能配置 / 万分比"/]:::attr
        A_M3_2[/"技能固定值 / 来自技能配置 / 整数"/]:::attr
        A_M3_1 -.-> M3
        A_M3_2 -.-> M3
    
        M1 --> M2
        M2 --> M3
    end
    
    %% =================================================
    %% Region 2
    %% =================================================
    subgraph R2["💥 Region 2 · 化解会心区"]
        direction LR
    
        CRIT_RATE["计算 ¤计算会心率<br/>¤计算会心率 ＝ F会心率❪MAX❪a.会心值 , 0❫❫ ＋ a.会心率"]:::interim
        CRIT_BRANCH{"掷骰判定 / 是否触发会心？"}:::branch
        A_CR_1[/"a.会心值 CRIT"/]:::attr
        A_CR_2[/"a.会心率 CRIT_PER"/]:::attr
        A_CR_1 -.-> CRIT_RATE
        A_CR_2 -.-> CRIT_RATE
        CRIT_RATE --> CRIT_BRANCH
    
        M4_YES["乘区4 · 会心触发<br/>输出 ＝ 乘区3输出 × ❮ 1.5 ＋ F会心倍率❪a.会伤值 − b.会伤减免值❫ ＋ a.会伤加成 − b.会伤减免 ❯"]:::formula
        M4_NO["乘区4 · 未触发<br/>输出 ＝ 乘区3输出 × 1"]:::formulaPass
        A_M4_1[/"a.会伤值 CRIT_DMG"/]:::attr
        A_M4_2[/"b.会伤减免值"/]:::attr
        A_M4_3[/"a.会伤加成 CRIT_DMG_PER"/]:::attr
        A_M4_4[/"b.会伤减免"/]:::attr
        A_M4_1 -.-> M4_YES
        A_M4_2 -.-> M4_YES
        A_M4_3 -.-> M4_YES
        A_M4_4 -.-> M4_YES
    
        CRIT_BRANCH -->|是| M4_YES
        CRIT_BRANCH -->|否| M4_NO
    
        DODGE_BRANCH{"伤害是否为直接伤害 且 触发化解？"}:::branch
    
        M5_YES["乘区5 · 化解触发<br/>¤计算化解率 ＝ F化解率❪MAX❪b.化解值 − a.精通值 , 0❫❫ ＋ b.化解率 − a.精通率<br/>输出 ＝ 乘区4输出 × MAX❮ 0.5 − F化解倍率❪b.化解效果值 − b.精通效果值❫ − b.化解效果率 ＋ a.精通效果率 , 0.25 封底25％ ❯"]:::formula
        M5_NO["乘区5 · 不化解<br/>输出 ＝ 乘区4输出 × 1"]:::formulaPass
        A_M5_1[/"b.化解值"/]:::attr
        A_M5_2[/"a.精通值（化解对抗）"/]:::attr
        A_M5_3[/"b.化解率"/]:::attr
        A_M5_4[/"a.精通率"/]:::attr
        A_M5_5[/"b.化解效果值"/]:::attr
        A_M5_6[/"b.精通效果值"/]:::attr
        A_M5_7[/"b.化解效果率"/]:::attr
        A_M5_8[/"a.精通效果率"/]:::attr
        A_M5_1 -.-> M5_YES
        A_M5_2 -.-> M5_YES
        A_M5_3 -.-> M5_YES
        A_M5_4 -.-> M5_YES
        A_M5_5 -.-> M5_YES
        A_M5_6 -.-> M5_YES
        A_M5_7 -.-> M5_YES
        A_M5_8 -.-> M5_YES
    
        M4_YES --> DODGE_BRANCH
        M4_NO --> DODGE_BRANCH
        DODGE_BRANCH -->|是| M5_YES
        DODGE_BRANCH -->|否| M5_NO
    end
    
    %% =================================================
    %% Region 3
    %% =================================================
    subgraph R3["🌀 Region 3 · 属性增伤区"]
        direction LR
    
        M6["乘区6 · 伤害加深<br/>输出 ＝ 上一乘区 × ❪1 ＋ a.伤害加深❫"]:::formula
        A_M6[/"a.伤害加深"/]:::attr
        A_M6 -.-> M6
    
        M7["乘区7 · 伤害弱化<br/>输出 ＝ 乘区6 × ❮1 − MIN❪b.受伤弱化 , 0.75 封顶75％❫❯"]:::formula
        A_M7[/"b.受伤弱化"/]:::attr
        A_M7 -.-> M7
    
        M8["乘区8 · 威压<br/>输出 ＝ 乘区7 × ❪a.威压 ／ b.威压❫<br/>※ 等级压制机制"]:::formula
        A_M8_1[/"a.威压"/]:::attr
        A_M8_2[/"b.威压"/]:::attr
        A_M8_1 -.-> M8
        A_M8_2 -.-> M8
    
        M9["乘区9 · 主类型增伤<br/>输出 ＝ 乘区8 × ❮1 ＋ Σ❪是否对应主类 ？ a.对应增伤 ： 0❫❯"]:::formula
        A_M9_1[/"a.功法技主类增伤"/]:::attr
        A_M9_2[/"a.心法主类增伤"/]:::attr
        A_M9_3[/"a.神识技主类增伤"/]:::attr
        A_M9_4[/"a.本命法宝技主类增伤"/]:::attr
        A_M9_5[/"...等所有主类增伤"/]:::attr
        A_M9_1 -.-> M9
        A_M9_2 -.-> M9
        A_M9_3 -.-> M9
        A_M9_4 -.-> M9
        A_M9_5 -.-> M9
    
        M10["乘区10 · 子类型增伤<br/>输出 ＝ 乘区9 × ❮1 ＋ Σ❪是否对应子类 ？ a.对应增伤 ： 0❫❯"]:::formula
        A_M10_1[/"a.招式子类增伤"/]:::attr
        A_M10_2[/"a.奇术子类增伤"/]:::attr
        A_M10_3[/"a.神通子类增伤"/]:::attr
        A_M10_4[/"a.驭兽技子类增伤"/]:::attr
        A_M10_5[/"...等所有子类增伤"/]:::attr
        A_M10_1 -.-> M10
        A_M10_2 -.-> M10
        A_M10_3 -.-> M10
        A_M10_4 -.-> M10
        A_M10_5 -.-> M10
    
        M11["乘区11 · 基础类型增伤<br/>＜直接伤害＞ 乘区10 × ❪1 ＋ a.直接伤害加深❫ ／ ＜间接伤害＞ 乘区10 × ❪1 ＋ a.间接伤害加深❫"]:::formula
        A_M11_1[/"a.直接伤害加深"/]:::attr
        A_M11_2[/"a.间接伤害加深"/]:::attr
        A_M11_1 -.-> M11
        A_M11_2 -.-> M11
    
        M12["乘区12 · 技能标签增伤<br/>输出 ＝ 乘区11 × ❪1 ＋ ¤标签增伤率❫<br/>※ 标签 ／ 飞弹 ／ 连击 ／ 叠伤 ／ 清算 ／ 标记 ..."]:::formula
        A_M12[/"¤标签增伤率 ＝ Σ匹配标签的增伤率<br/>例 a.飞弹标签增伤率 ／ a.连击标签增伤率 ..."/]:::attr
        A_M12 -.-> M12
    
        M13["乘区13 · 五行增伤<br/>输出 ＝ 乘区12 × ❮1 ＋ Σ❪是否对应五行 ？ F五行增伤❪a.五行增伤值❫ ＋ a.五行增伤率 ： 0❫ ＋ ❪是否任意五行 ？ F五行增伤❪a.全五行增伤值❫ ＋ a.全五行增伤率 ： 0❫❯"]:::formula
        A_M13_1[/"a.金／木／水／火／土 五行增伤值"/]:::attr
        A_M13_2[/"a.金／木／水／火／土 五行增伤率"/]:::attr
        A_M13_3[/"a.全五行增伤值／率"/]:::attr
        A_M13_1 -.-> M13
        A_M13_2 -.-> M13
        A_M13_3 -.-> M13
    
        M14["乘区14 · 五行减伤<br/>输出 ＝ 乘区13 × ❮1 − MIN❪Σ五行减伤项 , 0.75 封顶75％❫❯"]:::formula
        A_M14_1[/"b.金／木／水／火／土 五行减伤值"/]:::attr
        A_M14_2[/"b.金／木／水／火／土 五行减伤率"/]:::attr
        A_M14_3[/"b.全五行减伤值／率"/]:::attr
        A_M14_1 -.-> M14
        A_M14_2 -.-> M14
        A_M14_3 -.-> M14
    
        M15["乘区15 · 异常状态增伤<br/>输出 ＝ 乘区14 × ❮1 ＋ Σ❪对方对应异常 ？ a.对应异常增伤率 ： 0❫ ＋ ❪对方任意异常 ？ a.异常增伤率 ： 0❫❯"]:::formula
        A_M15_1[/"a.中毒异常增伤率"/]:::attr
        A_M15_2[/"a.眩晕异常增伤率"/]:::attr
        A_M15_3[/"a.减速异常增伤率"/]:::attr
        A_M15_4[/"a.异常增伤率 / 全异常通用"/]:::attr
        A_M15_1 -.-> M15
        A_M15_2 -.-> M15
        A_M15_3 -.-> M15
        A_M15_4 -.-> M15
    
        M6 --> M7 --> M8 --> M9 --> M10 --> M11 --> M12 --> M13 --> M14 --> M15
    end
    
    %% =================================================
    %% Region 4
    %% =================================================
    subgraph R4["✨ Region 4 · 战斗效果增伤区"]
        direction LR
    
        M16["乘区16 · 技能效果·被动增伤<br/>输出 ＝ 乘区15 × ❪1 ＋ a.技能效果·被动增伤率❫"]:::formula
        A_M16[/"a.技能效果·被动增伤率"/]:::attr
        A_M16 -.-> M16
    
        M17["乘区17 · 技能效果·被动减伤<br/>输出 ＝ 乘区16 × ❮1 − MIN❪b.技能效果·被动减伤率 , 0.75 封顶75％❫❯"]:::formula
        A_M17[/"b.技能效果·被动减伤率"/]:::attr
        A_M17 -.-> M17
    
        M18["乘区18 · 主动增伤 攻方<br/>输出 ＝ 乘区17 × ❮1 ＋ MAX❪a.主动技能自身增伤 − a.对方伤害降低 , −0.75 封底❫❯"]:::formula
        A_M18_1[/"a.技能效果·主动技能自身增伤 / 临时buff"/]:::attr
        A_M18_2[/"a.技能效果·对方伤害降低 / 挂在自己身上的虚弱debuff"/]:::attr
        A_M18_1 -.-> M18
        A_M18_2 -.-> M18
    
        M19["乘区19 · 主动减伤 守方<br/>输出 ＝ 乘区18 × ❮1 ＋ MAX❪b.对方受到伤害增加 − b.主动技能自身减伤 , −0.75 封底❫❯"]:::formula
        A_M19_1[/"b.技能效果·对方受到伤害增加 / 易伤debuff"/]:::attr
        A_M19_2[/"b.技能效果·主动技能自身减伤 / 守方临时减伤buff"/]:::attr
        A_M19_1 -.-> M19
        A_M19_2 -.-> M19
    
        M20["乘区20 · 局内条件增伤<br/>输出 ＝ 乘区19 × ❪1 ＋ a.局内条件增伤❫"]:::formula
        A_M20[/"a.局内条件增伤"/]:::attr
        A_M20 -.-> M20
    
        M21["乘区21 · 战斗道具增伤<br/>输出 ＝ 乘区20 × ❪1 ＋ a.技能效果·战斗道具增伤❫"]:::formula
        A_M21[/"a.技能效果·战斗道具增伤"/]:::attr
        A_M21 -.-> M21
    
        M22["乘区22 · 单位类型增伤<br/>输出 ＝ ※敌人类型对应增伤 × MIN❮0.75 , ❪1 − 我为妖王 ？ b.受妖王伤害降低 ： 0 − 我为修士 ？ b.受修士伤害降低 ： 0 − 我为召唤物 ？ b.受召唤物伤害降低 ： 0 ...❫❯"]:::formula
        A_M22_1[/"a.对妖王 ／ 对修士 ／ 对召唤物增伤 ..."/]:::attr
        A_M22_2[/"b.受妖王 ／ 受修士伤害降低 ..."/]:::attr
        A_M22_1 -.-> M22
        A_M22_2 -.-> M22
    
        M23["乘区23 · 玩法类型增伤<br/>＜演武＞ 乘区22 × ❮1 ＋ MAX❪a.演武伤害增加 − a.演武伤害降低 , −0.75❫❯ ／ ＜小秘境＞ ＜大秘境＞ ＜爬塔＞ 同构"]:::formula
        A_M23_1[/"a.玩法·演武伤害增加／降低"/]:::attr
        A_M23_2[/"a.玩法·小秘境伤害增加／降低"/]:::attr
        A_M23_3[/"a.玩法·大秘境伤害增加／降低"/]:::attr
        A_M23_4[/"a.玩法·爬塔伤害增加／降低"/]:::attr
        A_M23_1 -.-> M23
        A_M23_2 -.-> M23
        A_M23_3 -.-> M23
        A_M23_4 -.-> M23
    
        M24["乘区24 · 最终伤害增加<br/>输出 ＝ 乘区23 × ❪1 ＋ a.最终伤害增加❫"]:::formula
        A_M24[/"a.最终伤害增加 / 最稀有最强"/]:::attr
        A_M24 -.-> M24
    
        M25["乘区25 · 最终伤害减免<br/>最终伤害 ＝ 乘区24 × ❮1 − MIN❪b.最终伤害减免 , 0.75 封顶75％❫❯"]:::formula
        A_M25[/"b.最终伤害减免 / 守方终极减伤"/]:::attr
        A_M25 -.-> M25
    
        M16 --> M17 --> M18 --> M19 --> M20 --> M21 --> M22 --> M23 --> M24 --> M25
    end
    
    END([💥 最终伤害值 / 显示在被攻击者头顶]):::endNode
    
    START --> M1
    M3 --> CRIT_RATE
    M5_YES --> M6
    M5_NO --> M6
    M15 --> M16
    M25 --> END
    
    classDef start fill:#2E86AB,stroke:#1E5E7C,color:#fff,stroke-width:3px
    classDef endNode fill:#06A77D,stroke:#04644B,color:#fff,stroke-width:3px
    classDef formula fill:#FFF4D6,stroke:#D4A017,color:#000,stroke-width:2px
    classDef formulaPass fill:#F0F0F0,stroke:#888,color:#444,stroke-width:1px,stroke-dasharray: 5 5
    classDef interim fill:#FFE4B5,stroke:#CD853F,color:#000,stroke-width:1px
    classDef branch fill:#FFB347,stroke:#CC7722,color:#000,stroke-width:2px
    classDef attr fill:#E8F0FE,stroke:#4A90E2,color:#1A3A5C,stroke-width:1px
